# Переменные окружения для системы
# Скопируйте этот файл в .env и настройте под свои нужды

# ===========================================
# TELEGRAM BOT НАСТРОЙКИ
# ===========================================
# Получите токен от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Ваш Chat ID для получения уведомлений
ADMIN_CHAT_ID=your_chat_id_here
# Таймауты HTTP к api.telegram.org (сек.), если в логах «Timed out»
# TELEGRAM_CONNECT_TIMEOUT=30
# TELEGRAM_READ_TIMEOUT=30
# TELEGRAM_WRITE_TIMEOUT=30
# TELEGRAM_POOL_TIMEOUT=10
# Прокси при блокировке Telegram (или задайте HTTPS_PROXY)
# TELEGRAM_PROXY_URL=http://user:pass@proxy.example:8080

# ===========================================
# БАЗА ДАННЫХ
# ===========================================
DB_HOST=database
DB_PORT=5432
DB_NAME=digital_twin_db
DB_USER=process_user
DB_PASSWORD=process_password
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=postgres_password
DB_CONNECTION_TIMEOUT=30.0
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# ===========================================
# OPC UA СЕРВЕР
# ===========================================
OPCUA_SERVER_HOST=opcua-server
OPCUA_SERVER_PORT=4840
OPCUA_SERVER_ENDPOINT=opc.tcp://opcua-server:4840/freeopcua/server/
OPCUA_SERVER_TIMEOUT=10.0
OPCUA_SERVER_RETRY_ATTEMPTS=3
OPCUA_SERVER_RETRY_DELAY=1.0

# ===========================================
# КОНТРОЛЛЕРЫ
# ===========================================
CONTROLLER_MODE=primary
CONTROLLER_BACKUP_MODE=backup
CONTROLLER_HEARTBEAT_TIMEOUT=5.0
CONTROLLER_FAILOVER_DELAY=2.0
CONTROLLER_UPDATE_INTERVAL=0.1

# ===========================================
# АНАЛИТИКА
# ===========================================
ANALYTICS_PORT=8080
ANALYTICS_HOST=0.0.0.0
ANALYTICS_BASE_URL=http://analytics:8080
ANALYTICS_EXTERNAL_URL=http://localhost:8080
ANALYTICS_TIMEOUT=30.0
ANALYTICS_RETRY_ATTEMPTS=3

# ===========================================
# МОДЕЛЬ ПРОЦЕССА
# ===========================================
MODEL_UPDATE_INTERVAL=1.0
MODEL_LOG_LEVEL=INFO

# ===========================================
# WATCHDOG
# ===========================================
WATCHDOG_INTERVAL=5
WATCHDOG_TIMEOUT=30
WATCHDOG_UPDATE_INTERVAL=5.0

# ===========================================
# ОБЩИЕ НАСТРОЙКИ
# ===========================================
LOGGING_LEVEL=INFO
DEBUG_MODE=false
HEALTH_CHECK_INTERVAL=30.0
LOG_ROTATION_SIZE=10MB
LOG_RETENTION_DAYS=7
METRICS_COLLECTION_INTERVAL=60.0
